{
  "name": "voice-reminder",
  "version": "1.0.0",
  "description": "AI Voice Reminder Desktop Application",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --names \"BACKEND,ANGULAR,ELECTRON\" --prefix-colors \"green,blue,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:backend": "npm --prefix api-voice-reminder run dev",
    "dev:frontend": "npm --prefix app-voice-reminder run start",
    "dev:electron": "wait-on http://localhost:4200 && cross-env NODE_ENV=development electron .",
    "build:frontend": "npm --prefix app-voice-reminder run build",
    "build:backend": "echo 'Backend ready (no build step for Node.js)'",
    "build": "npm run build:frontend && npm run build:backend",
    "package": "npm run build && electron-builder",
    "electron:only": "electron .",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "sql.js": "^1.12.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "howler": "^2.2.4",
    "chrono-node": "^2.9.1",
    "compromise": "^14.15.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^31.7.2",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.voicereminder.app",
    "productName": "AI Voice Reminder",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "api-voice-reminder/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/icon.icns"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
